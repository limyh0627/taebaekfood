rules_version = '2';

/**
 * Firestore 보안 규칙
 *
 * ─ 현재 인증 구조 ─
 * 이 앱은 Firebase Anonymous Auth를 사용합니다.
 * 모든 접속자는 익명 Firebase 계정을 발급받으며, 직원 구분은
 * Firestore employees 컬렉션에서 username/password로 인앱 처리합니다.
 *
 * ─ 한계 ─
 * Firebase Auth 레벨에서 "이 사용자가 admin인지" 알 수 없습니다.
 * 현재 규칙은 최소한 미인증(익명 포함) 접근을 요구합니다.
 *
 * ─ Phase 3 권장 사항 ─
 * Firebase Authentication Custom Claims 도입 후
 * request.auth.token.isAdmin == true 조건으로 강화 필요
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // NOTE: Firebase Anonymous Auth 설정 완료 후 isAuthenticated() 조건으로 강화 가능
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
