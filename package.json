{
  "name": "taebaekfood",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build",
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:staff": "vite --config vite.staff.config.ts",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build:staff": "vite build --config vite.staff.config.ts",
    "build:all": "npm run build:admin && npm run build:staff",
    "deploy:admin": "npm run build:admin && firebase deploy --only hosting:admin",
    "deploy:staff": "npm run build:staff && firebase deploy --only hosting:staff",
    "deploy:all": "npm run build:all && firebase deploy --only hosting",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "firebase": "^12.9.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.460.0",
    "motion": "^12.34.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
